{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://brilla-backend-c435m.ondigitalocean.app",
        "EXPO_PUBLIC_USE_RN_FETCH": "1"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://brilla-backend-c435m.ondigitalocean.app",
        "EXPO_PUBLIC_USE_RN_FETCH": "1"
      }
    }
  },
  "submit": {
    "production": {
      "android": {}
    }
  }
}
