# Copy to .env and fill in the real Postgres connection string.
DATABASE_URL="postgresql://REPLACE_ME:REPLACE_ME@REPLACE_ME_HOST:5432/brilla?schema=public"

# Secret used to sign JWTs. Generate your own, e.g.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="REPLACE_ME"

# Cloudflare R2 (S3-compatible) bucket used for avatar uploads.
R2_ACCOUNT_ID="REPLACE_ME"
R2_ACCESS_KEY="REPLACE_ME"
R2_SECRET_KEY="REPLACE_ME"
R2_BUCKET_NAME="REPLACE_ME"
# Public base URL the bucket serves from (its r2.dev Public Development URL, or a custom domain), no trailing slash.
R2_PUBLIC_URL="REPLACE_ME"
